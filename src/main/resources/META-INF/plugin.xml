<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.muratiger.promptworkinglogs</id>
    <name>Prompt Work</name>
    <vendor>instantcoffeejp</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.intellij.plugins.markdown</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.muratiger.promptworkinglogs.settings.SimpleSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="com.github.muratiger.promptworkinglogs.settings.SimpleSettingsConfigurable"
            id="com.github.muratiger.promptworkinglogs.settings.SimpleSettingsConfigurable"
            displayName="Prompt Work"/>
        <notificationGroup id="prompt-work" displayType="BALLOON"/>
        <toolWindow id="prompt-work"
                    anchor="bottom"
                    icon="AllIcons.Actions.Execute"
                    factoryClass="com.github.muratiger.promptworkinglogs.toolwindow.ClaudeToolWindowFactory"/>
        <toolWindow id="prompt-work-files"
                    anchor="right"
                    icon="AllIcons.Toolwindows.Documentation"
                    factoryClass="com.github.muratiger.promptworkinglogs.toolwindow.PromptFilesToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="com.github.muratiger.promptworkinglogs.RunClaudeAction"
                class="com.github.muratiger.promptworkinglogs.action.RunClaudeAction"
                text="Run Claude Code"
                description="Run Claude Code on current markdown file"
                icon="/icons/claudeRun.svg"/>
        <action id="com.github.muratiger.promptworkinglogs.ToggleClaudeToolWindowMaximizedAction"
                class="com.github.muratiger.promptworkinglogs.action.ToggleClaudeToolWindowMaximizedAction"
                text="Toggle Prompt Work Pane Fullscreen"
                description="Maximize or restore the Prompt Work bottom tool window">
            <keyboard-shortcut keymap="$default" first-keystroke="control alt A"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="control alt A"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="control alt A"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
